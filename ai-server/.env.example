# 이 파일을 복사하여 .env 파일을 생성하세요.

# OpenAI API 설정 (필수)
GMS_API_KEY=your_gms_api_key_here
GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1

# AI 모델 설정 (필수)
GUARDRAIL_MODEL=gpt-5-mini
HINT_MODEL=gpt-5-mini

# 백엔드 서버 연동 설정
BACKEND_BASE_URL=http://localhost:8080
# BACKEND_API_TOKEN=your_token_here  # 선택사항

# 애플리케이션 설정 (선택, 기본값 있음)
# APP_TITLE=ErrorScape AI Server
# APP_VERSION=1.0.0
